      "expected_skill": "kast",
      "expected_route": "@kast",
      "allowed_ops": [
        "kast skill resolve",
        "kast skill rename",
        "kast skill diagnostics"
      ],
      "forbidden_ops": [
        "grep",
        "rg",
        "sed"
      ]
    },
    {
      "id": "fix-kotlin-test",
      "prompt": "Fix this failing Kotlin test by tracing the relevant production code and validating the edit.",
      "expected_skill": "kast",
