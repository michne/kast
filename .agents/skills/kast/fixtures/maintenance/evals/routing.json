    {
      "id": "recover-kast-bootstrap",
      "prompt": "I tried using Kast and the first command failed with `bash: : command not found` because `KAST_CLI_PATH` is empty. Bootstrap Kast for this workspace and keep tracing the Kotlin symbol semantically.",
      "expected_skill": "kast",
      "expected_route": "@kast",
      "allowed_ops": [
        "bash .agents/skills/kast/scripts/kast-session-start.sh",
        "kast skill scaffold",
